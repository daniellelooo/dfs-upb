# Copy to .env and adjust as needed:
#   cp .env.example .env

# Shared HMAC-SHA256 secret used to sign/verify JWT tokens.
# Must be the same in NameNode and all DataNodes (and at least 32 bytes).
JWT_SECRET=please-change-this-secret-please-change-this-secret

# DFS parameters
BLOCK_SIZE_MB=64
REPLICATION_FACTOR=2

# Host-side ports
NAMENODE_PORT=8080
DATANODE1_PORT=8081
DATANODE2_PORT=8082
DATANODE3_PORT=8083
